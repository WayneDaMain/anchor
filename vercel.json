{
  "outputDirectory": "build",
  "buildCommand": "vite build --sourcemap",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/__/auth/:path*",
      "destination": "https://anchor-b8fe6.firebaseapp.com/__/auth/:path*"
    },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
